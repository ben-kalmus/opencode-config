{
    "$schema": "https://opencode.ai/config.json",
    "permission": {
        "websearch": "allow"
    },
    "plugin": [
        "@rama_nigg/open-cursor@latest",
        "@tarquinen/opencode-dcp@latest",
        "superpowers@git+https://github.com/obra/superpowers.git"
    ],
    "provider": {
        "algolia-enablers": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "Algolia Enablers",
            "options": {
                "baseURL": "https://inference.api.enablers.algolia.net/v1",
                "apiKey": "{env:ENABLERS_JWT}"
            },
            "models": {
                "large": {
                    "name": "Large - MiniMax M2.5",
                    "limit": {
                        "context": 196000,
                        "output": 32000
                    }
                },
                "medium": {
                    "name": "Medium - Qwen3 VL 30B (high throughput)",
                    "limit": {
                        "context": 256000,
                        "output": 32000
                    }
                },
                "vision": {
                    "name": "Vision - Qwen3 VL 30B (multimodal)",
                    "limit": {
                        "context": 256000,
                        "output": 32000
                    }
                },
                "minimax-m2.5": {
                    "name": "MiniMax M2.5 (direct model access)",
                    "limit": {
                        "context": 196000,
                        "output": 32000
                    }
                },
                "qwen3-vl-30b-fp8": {
                    "name": "Qwen3 VL 30B FP8 (direct model access)",
                    "limit": {
                        "context": 256000,
                        "output": 32000
                    }
                }
            }
        },
        "ollama": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "Ollama (local)",
            "options": {
                "baseURL": "http://localhost:11434/v1"
            },
            "models": {
                "hf.co/unsloth/Qwen3-30B-A3B-GGUF:Q2_K": {
                    "limit": {
                        "context": 32768,
                        "output": 32768
                    }
                },
                "qwen3:14b": {
                    "limit": {
                        "context": 65536,
                        "output": 16384
                    }
                },
                "qwen2.5-coder:7b-extended": {
                    "name": "Qwen 2.5 Coder 7B Extended (local)",
                    "limit": {
                        "context": 65536,
                        "output": 16384
                    }
                }
            }
        },
        "llama-swap": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "llama-swap (local)",
            "options": {
                "baseURL": "http://localhost:11435/v1"
            },
            "models": {
                "qwen3.5-9b": {
                    "name": "Qwen 3.5 9B Q4_K_M (thinking)",
                    "limit": {
                        "context": 200000,
                        "output": 16384
                    }
                }
            }
        },
        "cursor-acp": {
            "name": "Cursor ACP",
